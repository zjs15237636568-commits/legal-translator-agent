# ======================================================
# Legal Translator Agent - Environment Variables Example
# 复制为 .env 后填入真实值即可。推荐通过前端「设置」页配置，
# 此文件主要用于 CI/CD 或无头部署场景。
# ======================================================

# 服务监听端口
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765

# 数据目录（SQLite + 加密配置存放位置）
DATA_DIR=./backend/data

# API Key 加密主密钥（AES-GCM）——首次启动如未设置会自动生成并保存
# 生产环境强烈建议手动指定一个 32 字节 base64 字符串
MASTER_KEY=

# 可选：直接通过环境变量提供模型 Key（优先级低于前端配置）
# OPENAI_API_KEY=sk-xxxx
# DEEPSEEK_API_KEY=sk-xxxx
# ANTHROPIC_API_KEY=sk-ant-xxxx

# 默认供应商：openai | deepseek | claude
DEFAULT_PROVIDER=deepseek
